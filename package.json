{
  "name": "style-bruxelles-palerme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "lint:style": "stylelint \"**/*.{css,scss,sass,html,vue}\" --ignore-path .gitignore",
    "lint:prettier": "prettier --check .",
    "lint": "npm run lint:style && npm run lint:prettier",
    "lintfix": "prettier --write --list-different . && npm run lint:style -- --fix",
    "prepare": "npm install husky && husky install",
    "preinstall": "npx npm-force-resolutions",
    "postinstall": "patch-package || echo 'Aucun patch trouvé, passage...'",
    "test": "jest"
  },
  "dependencies": {
    "@nuxt/icon": "^1.10.3",
    "@nuxt/image": "^1.9.0",
    "@nuxtjs/i18n": "^9.2.1",
    "core-js": "^3.25.3",
    "nuxt": "^3.15.4",
    "patch-package": "^8.0.0",
    "vue": "^3.5.13",
    "husky": "^8.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "stylelint": "^16.14.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@nuxt/kit": "^3.15.4",
    "@nuxt/types": "^2.15.8",
    "@nuxt/typescript-build": "^2.1.0",
    "@nuxtjs/stylelint-module": "^4.1.0",
    "@nuxtjs/tailwindcss": "^6.13.1",
    "@vue/test-utils": "^2.4.6",
    "babel-core": "7.0.0-bridge.0",
    "babel-jest": "^29.1.2",
    "eslint-config-prettier": "^8.5.0",
    "jest": "^29.1.2",
    "jest-environment-jsdom": "^29.1.2",
    "lint-staged": "^13.0.3",
    "postcss": "^8.4.17",
    "postcss-html": "^1.5.0",
    "prettier": "^2.7.1",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard": "^28.0.0",
    "ts-jest": "^29.0.3",
    "vue-jest": "^0.6.1"
  }
}
