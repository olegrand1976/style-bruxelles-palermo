{
  "name": "style-bruxelles-palerme",
  "version": "1.0.0",
  "private": true,
  "resolutions": {
    "unicorn-magic": "0.1.0"
  },
  "scripts": {
    "lint:style": "stylelint \"**/*.{css,scss,sass,html,vue}\" --ignore-path .gitignore",
    "lint:prettier": "prettier --check .",
    "lint:css": "stylelint '**/*.{css,scss}'",
    "lint:js": "eslint --ext .js,.vue --ignore-path .gitignore .",
    "lint": "npm run lint:style && npm run lint:prettier",
    "lintfix": "prettier --write --list-different . && npm run lint:style -- --fix",
    "preinstall": "npx npm-force-resolutions",
    "postinstall": "if [ -f node_modules/husky/lib/index.js ]; then npx husky install; else echo 'Husky not found, skipping...'; fi",
    "prepare": "if [ -f node_modules/husky/lib/index.js ]; then npx husky install; else echo 'Husky not found, skipping...'; fi",
    "test": "jest",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate"
  },
  "lint-staged": {
    "*.{css,scss,sass,html,vue}": "stylelint",
    "*.**": "prettier --check --ignore-unknown"
  },
  "dependencies": {
    "@iconify-json/uil": "^1.2.3",
    "@nuxt/image": "^1.9.0",
    "@nuxtjs/i18n": "^9.2.1",
    "@nuxtjs/tailwindcss": "^6.13.1",
    "fs-extra": "^10.1.0",
    "nuxt": "^3.6.0",
    "nuxt-icon": "^1.0.0-beta.7",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "^2.6.2",
    "@nuxt/types": "^2.15.8",
    "@types/node": "^22.13.5",
    "@vue/test-utils": "^2.4.6",
    "babel-jest": "^29.1.2",
    "husky": "^9.1.7",
    "jest": "^29.1.2",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "stylelint": "^16.14.1",
    "ts-jest": "^29.0.3",
    "typescript": "^5.8.2"
  },
  "stylelint": {
    "extends": "stylelint-config-standard"
  },
  "overrides": {
    "string-width": "4.2.3",
    "unicorn-magic": "0.1.0"
  }
}
